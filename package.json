{
  "name": "heydoctor-backend",
  "private": true,
  "version": "2.0.0",
  "description": "HeyDoctor Backend (NestJS)",
  "scripts": {
    "dev": "cd heydoctor-backend-pro && npm run start:dev",
    "build": "cd heydoctor-backend-pro && npm install && npm run build",
    "start": "cd heydoctor-backend-pro && npm run start",
    "start:prod": "cd heydoctor-backend-pro && npm run start:prod",

    "migration:run": "cd heydoctor-backend-pro && npm run typeorm migration:run",
    "migration:revert": "cd heydoctor-backend-pro && npm run typeorm migration:revert",

    "sync:frontend": "bash scripts/sync-frontend.sh",
    "sync:frontend:safe": "bash scripts/sync-frontend-safe.sh",
    "sync:frontend:check": "cd frontend && npm run lint && npm run build",

    "release:tag": "bash scripts/release-tag.sh",

    "strapi:start": "strapi start",
    "strapi:build": "strapi build",
    "strapi:develop": "strapi develop"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.700.0",
    "@clickhouse/client": "^1.18.2",
    "@sentry/node": "^10.42.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@socket.io/sticky": "^1.0.4",
    "@strapi/plugin-documentation": "^4.22.1",
    "@strapi/plugin-graphql": "4.22.1",
    "@strapi/plugin-i18n": "4.22.1",
    "@strapi/plugin-users-permissions": "4.22.1",
    "@strapi/provider-upload-cloudinary": "^4.22.1",
    "@strapi/strapi": "4.22.1",
    "@surunnuage/strapi-plugin-expo-notifications": "^2.0.4",
    "axios": "^1.6.8",
    "bullmq": "^5.34.0",
    "dotenv": "^16.6.1",
    "into-stream": "^6.0.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.3",
    "meilisearch": "^0.55.0",
    "pdfkit": "^0.15.0",
    "pg": "8.11.5",
    "qrcode": "^1.5.4",
    "rate-limiter-flexible": "^5.0.0",
    "socket.io": "^4.7.5",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=6.0.0"
  },
  "license": "MIT"
}
