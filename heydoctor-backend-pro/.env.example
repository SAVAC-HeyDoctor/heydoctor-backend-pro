# ─────────────────────────────────────────────────────────
# HeyDoctor Backend — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────────────────────

# ── CORE ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3001

# ── DATABASE (required) ─────────────────────────────────
# Railway provides DATABASE_PUBLIC_URL; local dev uses DATABASE_URL
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/heydoctor
# DATABASE_PUBLIC_URL=  # Set by Railway automatically
# Postgres TLS: en Railway el runtime se detecta vía RAILWAY_* y se ajusta el cliente.
# PEM de CA personalizada (opcional):
# DATABASE_SSL_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----"
# Forzar verificación estricta: DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Confiar cadena sin verificar (solo si conoces el riesgo): DATABASE_SSL_REJECT_UNAUTHORIZED=false

# ── AUTH (required) ──────────────────────────────────────
# Mismo valor para firmar tokens (login/refresh) y verificarlos (GET /auth/me).
# Railway: una variable JWT_SECRET por servicio; sin comillas extra en el valor.
# Generar: openssl rand -hex 32
JWT_SECRET=change-this-to-a-secure-random-string
# true = Logger.debug con claims del payload al entrar en validate() (sub/email/role)
JWT_DEBUG=false
# Cookie de sesión en API: dominio registrable compartido entre app y pro-api (producción).
# Ej. `.heydoctor.health` — SameSite=None + Secure ya lo fija `getSessionCookieOptions`.
# Desactivar Domain explícito: AUTH_COOKIE_DOMAIN=none
# AUTH_COOKIE_DOMAIN=.heydoctor.health

# ── CORS ─────────────────────────────────────────────────
# Orígenes adicionales (coma-separados) además de la lista fija en `main.ts`
# (incluye https://app.heydoctor.health y *.vercel.app en producción).
# Railway / producción ejemplo:
# CORS_ORIGIN=https://app.heydoctor.health
CORS_ORIGIN=http://localhost:3000
# Optional: comma-separated regex patterns matched against the request Origin
# header. Use this for Vercel preview deployments or other dynamic hostnames.
# Example: ^https:\/\/heydoctor-frontend-[a-z0-9-]+\.vercel\.app$
# Default Vercel previews of heydoctor-frontend are already allowed in main.ts;
# only set this when you need extra patterns.
# CORS_ORIGIN_REGEX=

# ── REDIS (optional) ─────────────────────────────────────
# Shared JWT validation cache, Nest cache manager, and rate-limit storage across instances
# Example: redis://default:password@host:6379
REDIS_URL=

# ── PAYKU (payment provider) ────────────────────────────
# true = no llamar a la API live de Payku; create-payment-session devuelve URL mock (reactivar: false o unset)
PAYKU_CONSULTATION_PAYMENTS_DISABLED=false
PAYKU_API_URL=https://app.payku.cl/api
PAYKU_API_KEY=
PAYKU_WEBHOOK_SECRET=
PAYKU_WEBHOOK_BEARER=
# Allow webhook without auth in local dev (never in production)
PAYKU_WEBHOOK_ALLOW_UNSAFE_LOCAL=false
# Payment amount in CLP (default: 15000)
CONSULTATION_PAYMENT_AMOUNT_CLP=15000
# Minutes before pending payment expires (default: 1440 = 24h)
PAYMENT_PENDING_EXPIRE_MINUTES=1440

# ── OPENAI (AI features) ────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── COMPLIANCE ───────────────────────────────────────────
# Enable HIPAA-mode: stricter logging, shorter sessions
HIPAA_MODE=false

# ── URLS ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
BACKEND_PUBLIC_URL=http://localhost:3001

# ── WEBRTC (teleconsultation) ───────────────────────────
# Comma-separated STUN servers. If unset, defaults to Google's public STUN.
# WEBRTC_STUN_URLS=stun:stun.l.google.com:19302,stun:stun1.l.google.com:19302
# Optional TURN credentials (required for clients behind strict NAT/firewalls).
# Provide all three to enable TURN; otherwise only STUN is returned.
# WEBRTC_TURN_URLS=turn:turn.example.com:3478?transport=udp,turn:turn.example.com:3478?transport=tcp
# WEBRTC_TURN_USERNAME=
# WEBRTC_TURN_CREDENTIAL=
